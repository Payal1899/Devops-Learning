1. Creating and Renaming Files/Directories
#creates directory with name test_dir
@Payal1899 ➜ /workspaces/Devops-Learning (Assignment) $ ls
Assignment-1
@Payal1899 ➜ /workspaces/Devops-Learning (Assignment) $ mkdir test_dir
@Payal1899 ➜ /workspaces/Devops-Learning (Assignment) $ ls
Assignment-1  test_dir

#Changing directory to test_dir 
@Payal1899 ➜ /workspaces/Devops-Learning (Assignment) $ cd test_dir

#creating empty file named example.txt
@Payal1899 ➜ /workspaces/Devops-Learning/test_dir (Assignment) $ touch example.txt
@Payal1899 ➜ /workspaces/Devops-Learning/test_dir (Assignment) $ ls
example.txt

#renaming the same file with mv command to renamed_example.txt
@Payal1899 ➜ /workspaces/Devops-Learning/test_dir (Assignment) $ mv example.txt 
renamed_example.txt
@Payal1899 ➜ /workspaces/Devops-Learning/test_dir (Assignment) $ ls
renamed_example.txt


